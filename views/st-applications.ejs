<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Applications</title>
<link rel="stylesheet" href="/student-styling/st-applications.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<!-- Navbar -->
<nav class="navbar">
  <a class="nav-logo" href="/student/homepage">Team<span>Match</span></a>
  <div class="nav-links">
    <a href="/student/projects" class="nav-link">Browse Projects</a>
    <a href="/student/myprojects" class="nav-link">My Projects</a>
    <a href="/student/applications" class="nav-link active">My Applications</a>
    <a href="/student/announcements" class="nav-link">Announcements</a>
    <a href="/student/find/advisors" class="nav-link">Find Advisor</a>
    <a href="/student/requests" class="nav-link">Advisor Requests</a>
    <a href="/student/applicants" class="nav-link">Applicants</a>
  </div>
  <div class="nav-actions">
    <a href="/student/profile" class="nav-btn-outline">Profile</a>
    <a href="/logout" class="nav-btn-logout">Logout</a>
  </div>
</nav>

<!-- Page Header -->
<div class="page-header">
  <div class="page-header-inner">
    <div class="page-eyebrow">Student Portal</div>
    <h1 class="page-title">My Applications</h1>
    <p class="page-sub">Track the projects you've applied to join.</p>
  </div>
</div>

<div class="container">

<% if (applications && applications.length > 0) { %>

  <!-- Toolbar -->
  <div class="toolbar">
    <span class="results-count">
      <strong><%= applications.length %></strong> application<%= applications.length !== 1 ? 's' : '' %>
    </span>
    <a href="/student/projects" class="btn-outline">Browse more projects →</a>
  </div>

  <!-- Applications Grid -->
  <div class="apps-grid">

    <% applications.forEach(app => { %>
    <div class="app-card">

      <!-- Top accent stripe via ::before, status drives color via data attr -->
      <div class="app-card-inner" data-status="<%= app.status ? app.status.toLowerCase() : 'pending' %>">

        <!-- Card Top: status badge + withdraw -->
        <div class="ac-topbar">
          <span class="status-badge status-<%= app.status ? app.status.toLowerCase() : 'pending' %>">
            <span class="status-dot"></span>
            <%= app.status ? app.status.charAt(0).toUpperCase() + app.status.slice(1).toLowerCase() : 'Pending' %>
          </span>
          <form id="withdraw-form-<%= app.request_id %>" action="/student/applications/<%= app.request_id %>/delete?_method=DELETE" method="POST">
            <button
              type="button"
              class="withdraw-btn"
              data-request-id="<%= app.request_id %>"
              data-project-title="<%- app.project_title %>"
              onclick="openWithdrawModal(this)"
              title="Withdraw application">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
              Withdraw
            </button>
          </form>
        </div>

        <!-- Project Title -->
        <div class="ac-title-wrap">
          <h3 class="ac-title"><%= app.project_title %></h3>
          <span class="ac-category"><%= app.category_name %></span>
        </div>

        <!-- Applicant Info -->
        <div class="ac-info-grid">
          <div class="ac-info-item">
            <span class="ac-info-label">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              Applicant
            </span>
            <span class="ac-info-value"><%= app.full_name %></span>
          </div>
          <!-- <div class="ac-info-item">
            <span class="ac-info-label">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Department
            </span>
            <span class="ac-info-value"><%= app.department %></span>
          </div> -->
          <div class="ac-info-item">
            <span class="ac-info-label">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              Email
            </span>
            <span class="ac-info-value ac-email"><%= app.email %></span>
          </div>
          <div class="ac-info-item">
            <span class="ac-info-label">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Applied
            </span>
            <span class="ac-info-value"><%= new Date(app.request_date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
          </div>
        </div>

        <!-- Skills -->
        <% if (app.request_skills) { %>
        <div class="ac-skills-wrap">
          <span class="ac-info-label">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Skills
          </span>
          <div class="ac-skills">
            <% app.request_skills.split(',').forEach(skill => { %>
              <span class="skill-tag"><%= skill.trim() %></span>
            <% }) %>
          </div>
        </div>
        <% } %>

        <!-- Message -->
        <% if (app.request_message) { %>
        <div class="ac-message-wrap">
          <div class="ac-message-label">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Your Message
          </div>
          <p class="ac-message"><%= app.request_message %></p>
        </div>
        <% } %>

      </div>
    </div>
    <% }) %>

  </div>

<% } else { %>

  <!-- Empty State -->
  <div class="empty-state">
    <div class="empty-icon">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
    </div>
    <div class="empty-title">No applications yet</div>
    <p class="empty-sub">You haven't applied to any projects. Browse open projects and find your next collaboration.</p>
    <a href="/student/projects" class="btn-primary">Browse Projects →</a>
  </div>

<% } %>

</div>

<!-- ══════════════════════════════════════════
     WITHDRAW CONFIRMATION MODAL
══════════════════════════════════════════ -->
<div class="modal-overlay" id="withdrawModal" aria-modal="true" role="dialog" aria-labelledby="modal-title">
  <div class="modal">
    <div class="modal-icon-wrap">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
    </div>
    <div class="modal-body">
      <h2 class="modal-title" id="modal-title">Withdraw Application?</h2>
      <p class="modal-desc">You're about to withdraw your application for</p>
      <p class="modal-project-name" id="modal-project-name"></p>
      <p class="modal-warning">This action is permanent and cannot be undone. The project owner will no longer be able to review your submission.</p>
    </div>
    <div class="modal-actions">
      <button class="modal-btn-cancel" id="modalCancelBtn" type="button">Keep Application</button>
      <button class="modal-btn-confirm" id="modalConfirmBtn" type="button">Yes, Withdraw</button>
    </div>
  </div>
</div>

<footer class="footer">
  <div class="footer-inner">
    <span class="footer-logo">Team<span>Match</span></span>
    <span class="footer-copy">University Project Collaboration Platform</span>
  </div>
</footer>

<script>
  let _pendingFormId = null;

  function openWithdrawModal(btn) {
    const requestId = btn.dataset.requestId;
    const projectTitle = btn.dataset.projectTitle;
    _pendingFormId = 'withdraw-form-' + requestId;
    document.getElementById('modal-project-name').textContent = projectTitle;
    const modal = document.getElementById('withdrawModal');
    modal.classList.add('is-visible');
    document.body.style.overflow = 'hidden';
    document.getElementById('modalCancelBtn').focus();
  }

  function closeWithdrawModal() {
    const modal = document.getElementById('withdrawModal');
    modal.classList.remove('is-visible');
    document.body.style.overflow = '';
    _pendingFormId = null;
  }

  document.getElementById('modalCancelBtn').addEventListener('click', closeWithdrawModal);

  document.getElementById('modalConfirmBtn').addEventListener('click', function () {
    if (_pendingFormId) {
      document.getElementById(_pendingFormId).submit();
    }
  });

  document.getElementById('withdrawModal').addEventListener('click', function (e) {
    if (e.target === this) closeWithdrawModal();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeWithdrawModal();
  });
</script>

</body>
</html>
