<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password · TeamMatch</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=Syne:wght@700;800&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/auth-styling/reset.css" />
</head>
<body>

  <div class="page">

    <!-- Brand -->
    <div class="brand">Team<span>Match</span></div>

    <!-- Heading -->
    <div class="page-top">
      <div class="page-title">Forgot password?</div>
      <div class="page-sub">Enter the email linked to your account and we'll send you a verification code</div>
    </div>

    <!-- Form card -->
    <div class="form-card">

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-msg">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
          </svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/reset-password" method="POST" id="forgot-form" novalidate>

        <!-- Email -->
        <div class="field-group">
          <label class="field-label" for="email">Email Address</label>
          <div class="input-wrap">
            <span class="input-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </span>
            <input
              type="email"
              id="email"
              name="email"
              class="field-input"
              placeholder="you@example.com"
              autocomplete="email"
              required
            />
          </div>
          <div class="field-error" id="email-error">Enter a valid email address.</div>
        </div>

        <button type="submit" class="signin-btn">Send Code</button>

      </form>

      <!-- Back link -->
      <div class="back-link" style="text-align: center;">
        <a href="/login">
          <button type="button" class="back-btn">&larr; Back to sign in</button>
        </a>
      </div>

    </div>

  </div>

  <script>
    document.getElementById('forgot-form').addEventListener('submit', function (e) {
      var email = document.getElementById('email');
      var emailError = document.getElementById('email-error');
      var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

      email.classList.remove('input-invalid');
      emailError.classList.remove('visible');

      if (!emailPattern.test(email.value.trim())) {
        email.classList.add('input-invalid');
        emailError.classList.add('visible');
        e.preventDefault();
      }
    });
  </script>

</body>
</html>
