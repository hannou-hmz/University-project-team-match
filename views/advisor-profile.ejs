<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Advisor Profile — TeamMatch</title>
<link rel="stylesheet" href="/advisor-styling/advisor-profile.css">
<link rel="icon" href="/img/fav.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>

<!-- ── Navbar ────────────────────────────── -->
<nav class="navbar">
<a class="nav-logo" href="/advisor/dashboard">Team<span>Match</span></a>
<div class="nav-actions">
    <a href="/advisor/dashboard" class="nav-btn-outline">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Dashboard
    </a>
    <a href="/logout" class="nav-btn-logout">Logout</a>
</div>
</nav>

<!-- ── Profile Hero Banner ───────────────── -->
<div class="profile-hero">
<div class="profile-hero-bg">
    <div class="hero-circle-1"></div>
    <div class="hero-circle-2"></div>
</div>

<!-- Profile Bar (sits below hero, avatar overlaps) -->
<div class="profile-bar">
    <div class="profile-bar-inner">

        <!-- Avatar -->
        <div class="avatar-wrap">
            <div class="avatar" id="avatarDisplay">
                <img id="preview"
                    src="../static-files/profile-photos/default.jpg user.profile_photo || 'default.jpg' %>"
                    alt="Profile Photo"
                    onerror="this.style.display='none'; document.getElementById('avatarInitials').style.display='flex';">
                <div id="avatarInitials" class="avatar-initials">
                    <%= advisor.full_name ? advisor.full_name.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase() : 'AD' %>
                </div>
            </div>
            <div class="avail-indicator <%= advisor.available ? 'is-available' : 'is-unavailable' %>"
                title="<%= advisor.available ? 'Available for advising' : 'Not available' %>"></div>
        </div>

        <!-- Identity -->
        <div class="profile-identity">
            <h1 class="profile-name"><%= advisor.full_name %></h1>
            <div class="profile-meta-row">
                <span class="profile-badge title-badge">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                    <%= advisor.academic_title || 'Faculty Advisor' %>
                </span>
                <span class="profile-badge dept-badge">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                    <%= advisor.department_name %>
                </span>
                <span class="avail-pill <%= advisor.available ? 'avail-pill-on' : 'avail-pill-off' %>">
                    <span class="avail-dot <%= advisor.available ? 'avail-dot-on' : 'avail-dot-off' %>"></span>
                    <%= advisor.available ? 'Accepting requests' : 'Unavailable' %>
                </span>
            </div>
            <div class="profile-contact-row">
                <span class="profile-contact-item">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <%= advisor.email %>
                </span>
            </div>
        </div>

        <!-- Stats (decorative — replace values as needed) -->
        <div class="profile-stats">
            <div class="stat-item">
                <div class="stat-num">12</div>
                <div class="stat-label">Students</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-num">5</div>
                <div class="stat-label">Projects</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-num">3</div>
                <div class="stat-label">Active Req.</div>
            </div>
        </div>

    </div>
</div>
</div>

<!-- ── Main content ──────────────────────── -->
<div class="page-wrap">
<div class="main-grid">

    <!-- ── Left Column ─────────────────── -->
    <div class="col-left">

        <!-- Account Details Card -->
        <div class="card">
            <div class="card-header">
                <div class="card-header-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="card-header-text">
                    <div class="card-header-title">Account Details</div>
                    <div class="card-header-sub">Your registered information</div>
                </div>
            </div>
            <div class="info-list">
                <div class="info-row">
                    <span class="info-label">Full Name</span>
                    <span class="info-value"><%= advisor.full_name %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Email</span>
                    <span class="info-value"><%= advisor.email %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Department</span>
                    <span class="info-value"><%= advisor.department_name %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Title</span>
                    <span class="info-value"><%= advisor.academic_title || '—' %></span>
                </div>
            </div>
        </div>

        <!-- Expertise Card -->
        <div class="card">
            <div class="card-header">
                <div class="card-header-icon">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <div class="card-header-text">
                    <div class="card-header-title">Areas of Expertise</div>
                    <div class="card-header-sub">Your academic focus areas</div>
                </div>
            </div>
            <div class="expertise-wrap">
                <% if (advisor.areas_of_expertise) { %>
                    <% advisor.areas_of_expertise.split(',').map(s => s.trim()).filter(Boolean).forEach(tag => { %>
                        <span class="exp-tag"><%= tag %></span>
                    <% }) %>
                <% } else { %>
                    <span style="font-size:0.82rem;color:var(--muted);padding:4px 0;">No expertise areas added yet.</span>
                <% } %>
            </div>
        </div>

        <!-- Availability Status Card -->
        <div class="card">
            <div class="avail-status-card <%= advisor.available ? 'status-on' : 'status-off' %>">
                <div class="avail-status-icon <%= advisor.available ? 'icon-on' : 'icon-off' %>">
                    <% if (advisor.available) { %>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    <% } else { %>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                    <% } %>
                </div>
                <div>
                    <div class="avail-status-label"><%= advisor.available ? 'Open for Advising' : 'Currently Unavailable' %></div>
                    <div class="avail-status-sub">Students <%= advisor.available ? 'can' : 'cannot' %> send you advising requests right now.</div>
                </div>
            </div>
        </div>

    </div>

    <!-- ── Right Column ─────────────────── -->
    <div class="col-right">
        <div class="card" style="border-radius: 0 0 var(--radius) var(--radius); overflow: visible;">

            <!-- Tab navigation -->
            <div class="section-tabs" id="profileTabs" style="border-radius: var(--radius) var(--radius) 0 0; overflow: hidden;">
                <button class="section-tab active" data-tab="profile">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit Profile
                </button>
                <button class="section-tab" data-tab="password">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    Change Password
                </button>
            </div>

            <!-- ── Tab: Edit Profile ──────── -->
            <div class="tab-panel active" id="tab-profile">
                <form action="/advisor/profile" method="POST">
                    <div class="form-body">

                        <div class="form-section-title">Professional Information</div>

                        <div class="form-row">
                            <div class="form-group" style="margin-bottom:0;">
                                <label class="form-label" for="academic_title">Academic Title</label>
                                <input class="form-input" type="text" id="academic_title" name="academic_title"
                                    value="<%= advisor.academic_title %>"
                                    placeholder="e.g. Associate Professor">
                            </div>
                            <div class="form-group" style="margin-bottom:0;">
                                <label class="form-label" for="department_display">Department</label>
                                <input class="form-input readonly-field" type="text" id="department_display"
                                    value="<%= advisor.department_name %>" readonly>
                            </div>
                        </div>

                        <div class="form-group" style="margin-top:20px;">
                            <label class="form-label" for="expertise">Areas of Expertise</label>
                            <input class="form-input" type="text" id="expertise" name="expertise"
                                value="<%= advisor.areas_of_expertise %>"
                                placeholder="e.g. Machine Learning, Computer Vision, NLP">
                            <p class="input-hint">
                                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                                Separate areas with commas. These appear as tags on your profile.
                            </p>
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="researches">Research Interests & Projects</label>
                            <textarea class="form-textarea" id="researches" name="researches" rows="5"
                                placeholder="Describe your current research projects, methodologies, and what kind of student projects align with your interests..."><%= advisor.research %></textarea>
                        </div>

                        <hr class="form-divider">

                        <div class="form-section-title">Availability Settings</div>

                        <!-- Availability toggle -->
                        <div class="avail-toggle-wrap">
                            <div class="avail-toggle-left">
                                <div class="avail-toggle-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                </div>
                                <div>
                                    <div class="avail-toggle-title">Open for Advising Requests</div>
                                    <div class="avail-toggle-sub">When enabled, students can send you project advising requests</div>
                                </div>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" name="available" value="1" <%= advisor.available ? 'checked' : '' %>>
                                <span class="toggle-slider"></span>
                            </label>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="submit-btn">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                Save Changes
                            </button>
                            <button type="reset" class="btn-secondary">Reset</button>
                        </div>

                    </div>
                </form>
            </div>

            <!-- ── Tab: Change Password ───── -->
            <div class="tab-panel" id="tab-password">
                <form action="/advisor/profile/change-password" method="POST">
                    <div class="form-body">

                        <div class="alert alert-info">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <span>Your password must be at least 8 characters and contain uppercase, lowercase, and a number. You will remain logged in after changing your password.</span>
                        </div>

                        <div class="form-section-title">Current Credentials</div>

                        <div class="form-group">
                            <label class="form-label" for="current_email_disp">Email Address</label>
                            <div class="input-icon-wrap">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                <input class="form-input readonly-field" type="email" id="current_email_disp"
                                    value="<%= advisor.email %>" readonly>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="currentPassword">
                                Current Password <span class="label-required">*</span>
                            </label>
                            <div class="password-wrap">
                                <input class="form-input" type="password" id="current_password" name="currentPassword"
                                    placeholder="Enter your current password" autocomplete="current-password" required>
                                <button type="button" class="pwd-toggle" onclick="togglePwd('currentPassword', this)" aria-label="Show/hide password">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                            </div>
                        </div>

                        <hr class="form-divider">

                        <div class="form-section-title">New Password</div>

                        <div class="form-group">
                            <label class="form-label" for="newPassword">
                                New Password <span class="label-required">*</span>
                            </label>
                            <div class="password-wrap">
                                <input class="form-input" type="password" id="new_password" name="newPassword"
                                    placeholder="Create a strong password" autocomplete="new-password" required
                                    oninput="checkStrength(this.value)">
                                <button type="button" class="pwd-toggle" onclick="togglePwd('newPassword', this)" aria-label="Show/hide password">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                            </div>

                            <!-- Strength meter -->
                            <div class="password-strength">
                                <div class="strength-bar">
                                    <div class="strength-fill" id="strengthFill"></div>
                                </div>
                                <div class="strength-label" id="strengthLabel">Enter a password to check strength</div>
                            </div>

                            <!-- Requirements checklist -->
                            <div class="pwd-requirements" id="pwdReqs">
                                <div class="pwd-req" id="req-len">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    Min. 8 characters
                                </div>
                                <div class="pwd-req" id="req-upper">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    Uppercase letter
                                </div>
                                <div class="pwd-req" id="req-lower">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    Lowercase letter
                                </div>
                                <div class="pwd-req" id="req-num">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                    Number (0–9)
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label" for="confirmPassword">
                                Confirm New Password <span class="label-required">*</span>
                            </label>
                            <div class="password-wrap">
                                <input class="form-input" type="password" id="confirm_password" name="confirmPassword"
                                    placeholder="Re-enter your new password" autocomplete="new-password" required
                                    oninput="checkMatch()">
                                <button type="button" class="pwd-toggle" onclick="togglePwd('confirmPassword', this)" aria-label="Show/hide password">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                            </div>
                            <p class="input-hint" id="matchHint" style="display:none;"></p>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="submit-btn">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                Update Password
                            </button>
                            <button type="reset" class="btn-secondary">Clear</button>
                        </div>

                    </div>
                </form>
            </div>

        </div>
    </div>

</div>
</div>

<!-- ── Footer ────────────────────────────── -->
<footer class="footer">
<div class="footer-inner">
    <span class="footer-logo">Team<span>Match</span></span>
    <span class="footer-copy">© 2025 University Project Collaboration Platform. All rights reserved.</span>
</div>
</footer>

<script>
/* ── Tab switching ───────────────────────── */
document.querySelectorAll('.section-tab').forEach(tab => {
tab.addEventListener('click', () => {
    const target = tab.dataset.tab;
    document.querySelectorAll('.section-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    tab.classList.add('active');
    document.getElementById('tab-' + target).classList.add('active');
});
});

/* ── Password visibility toggle ─────────── */
function togglePwd(inputId, btn) {
const input = document.getElementById(inputId);
const isText = input.type === 'text';
input.type = isText ? 'password' : 'text';
btn.innerHTML = isText
    ? `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`
    : `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`;
}

/* ── Password strength meter ─────────────── */
function checkStrength(val) {
const fill  = document.getElementById('strengthFill');
const label = document.getElementById('strengthLabel');

const hasLen   = val.length >= 8;
const hasUpper = /[A-Z]/.test(val);
const hasLower = /[a-z]/.test(val);
const hasNum   = /[0-9]/.test(val);
const hasSpec  = /[^A-Za-z0-9]/.test(val);

toggleReq('req-len',   hasLen);
toggleReq('req-upper', hasUpper);
toggleReq('req-lower', hasLower);
toggleReq('req-num',   hasNum);

const score = [hasLen, hasUpper, hasLower, hasNum, hasSpec].filter(Boolean).length;
const levels = [
    { pct: '0%',   color: 'var(--line)',  text: '' },
    { pct: '20%',  color: '#ef4444',       text: 'Very Weak' },
    { pct: '40%',  color: '#f97316',       text: 'Weak' },
    { pct: '60%',  color: '#eab308',       text: 'Fair' },
    { pct: '80%',  color: '#22c55e',       text: 'Strong' },
    { pct: '100%', color: '#16a34a',       text: 'Very Strong' },
];
const l = levels[score];
fill.style.width = l.pct;
fill.style.background = l.color;
label.textContent = l.text ? `Password strength: ${l.text}` : 'Enter a password to check strength';
label.style.color = score >= 4 ? '#16a34a' : (score >= 3 ? '#eab308' : 'var(--muted)');
}

function toggleReq(id, met) {
const el = document.getElementById(id);
if (met) el.classList.add('met'); else el.classList.remove('met');
}

/* ── Confirm password match ──────────────── */
function checkMatch() {
const np = document.getElementById('new_password').value;
const cp = document.getElementById('confirm_password').value;
const hint = document.getElementById('matchHint');
if (!cp) { hint.style.display = 'none'; return; }
hint.style.display = 'flex';
if (np === cp) {
    hint.style.color = 'var(--green)';
    hint.textContent = '✓ Passwords match';
} else {
    hint.style.color = 'var(--red)';
    hint.textContent = '✗ Passwords do not match';
}
}
</script>
</body>
</html>
