<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>429 — Too Many Attempts · TeamMatch</title>
  <link rel="icon" href="/img/fav.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Syne:wght@600;700;800&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:    #0a0f1e;
      --muted:   #6b7a99;
      --line:    #e4e9f2;
      --surface: #f4f6fb;
      --white:   #ffffff;
      --accent:  #2563ff;
      --accent2: #0ea5e9;
      --amber:   #f59e0b;
      --text:    #1a2135;
      --text-sm: #4b5978;

      --radius-lg: 16px;
      --shadow-lg: 0 12px 48px rgba(10,15,30,0.13);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--surface);
      color: var(--text);
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    /* ── Ambient background blobs ── */
    body::before,
    body::after {
      content: '';
      position: fixed;
      border-radius: 50%;
      pointer-events: none;
      z-index: 0;
    }
    body::before {
      width: 520px;
      height: 520px;
      background: radial-gradient(circle, rgba(245,158,11,0.08) 0%, transparent 70%);
      top: -130px;
      right: -90px;
    }
    body::after {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(37,99,255,0.06) 0%, transparent 70%);
      bottom: -100px;
      left: -60px;
    }

    /* ── Card ── */
    .error-card {
      position: relative;
      z-index: 1;
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      padding: 52px 48px 44px;
      max-width: 520px;
      width: 100%;
      text-align: center;

      opacity: 0;
      transform: translateY(18px);
      animation: fadeUp 0.55s cubic-bezier(0.34, 1.2, 0.64, 1) 0.08s forwards;
    }

    @keyframes fadeUp {
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Brand strip ── */
    .card-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-bottom: 36px;
    }

    .brand-logo {
      width: 34px;
      height: 34px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 9px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      box-shadow: 0 3px 12px rgba(37,99,255,0.35);
      flex-shrink: 0;
    }

    .brand-name {
      font-family: 'Syne', sans-serif;
      font-size: 1.05rem;
      font-weight: 800;
      color: var(--navy);
      letter-spacing: -0.4px;
    }
    .brand-name em { font-style: normal; color: var(--accent); }

    /* ── Error icon ── */
    .error-icon-wrap {
      width: 72px;
      height: 72px;
      border-radius: 20px;
      background: linear-gradient(160deg, #fffbeb 30%, #fef3c7);
      border: 1px solid #fde68a;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
      color: #b45309;
      box-shadow: 0 4px 16px rgba(245,158,11,0.16);

      opacity: 0;
      transform: scale(0.88);
      animation: popIn 0.45s cubic-bezier(0.34, 1.4, 0.64, 1) 0.28s forwards;
    }

    @keyframes popIn {
      to { opacity: 1; transform: scale(1); }
    }

    /* Lock pulse ring */
    .error-icon-wrap::after {
      content: '';
      position: absolute;
      width: 72px;
      height: 72px;
      border-radius: 20px;
      border: 2px solid rgba(245,158,11,0.3);
      animation: ringPulse 2.2s ease-in-out infinite;
    }

    @keyframes ringPulse {
      0%, 100% { transform: scale(1);    opacity: 0.6; }
      50%       { transform: scale(1.14); opacity: 0; }
    }

    /* ── Code badge ── */
    .error-code {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #92400e;
      background: #fef3c7;
      border: 1px solid #fde68a;
      padding: 4px 12px;
      border-radius: 50px;
      margin-bottom: 14px;
    }

    /* ── Title ── */
    .error-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--navy);
      letter-spacing: -0.8px;
      line-height: 1.15;
      margin-bottom: 12px;
    }

    .error-title span {
      display: block;
      font-size: 3.2rem;
      letter-spacing: -3px;
      line-height: 1;
      background: linear-gradient(135deg, #92400e, var(--amber));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 6px;
    }

    /* ── Message ── */
    .error-message {
      font-size: 0.9rem;
      color: var(--text-sm);
      line-height: 1.65;
      max-width: 360px;
      margin: 0 auto 22px;
    }

    /* ── Countdown ── */
    .cooldown-wrap {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-radius: 12px;
      padding: 14px 20px;
      margin: 0 auto 24px;
      max-width: 320px;
    }

    .cooldown-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      background: #fef3c7;
      border: 1px solid #fde68a;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #b45309;
      flex-shrink: 0;
    }

    .cooldown-text {
      text-align: left;
    }

    .cooldown-label {
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #92400e;
      margin-bottom: 2px;
    }

    .cooldown-timer {
      font-family: 'Syne', sans-serif;
      font-size: 1.3rem;
      font-weight: 800;
      color: #78350f;
      letter-spacing: -0.5px;
      line-height: 1;
    }

    /* ── Progress bar ── */
    .progress-wrap {
      margin: 0 auto 28px;
      max-width: 360px;
    }

    .progress-labels {
      display: flex;
      justify-content: space-between;
      font-size: 0.72rem;
      color: var(--muted);
      font-weight: 500;
      margin-bottom: 7px;
    }

    .progress-bar {
      width: 100%;
      height: 6px;
      background: var(--line);
      border-radius: 50px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #d97706, var(--amber));
      border-radius: 50px;
      width: 100%;
      transform-origin: left;
      animation: drainProgress 300s linear forwards;
    }

    @keyframes drainProgress {
      from { width: 100%; }
      to   { width: 0%;   }
    }

    /* ── Divider ── */
    .error-divider {
      height: 1px;
      background: var(--line);
      margin: 0 0 24px;
    }

    /* ── Actions ── */
    .error-actions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: 'Outfit', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      border: none;
      cursor: pointer;
      border-radius: 8px;
      padding: 10px 20px;
      text-decoration: none;
      transition: transform .15s, box-shadow .15s;
      white-space: nowrap;
    }
    .btn:hover { transform: translateY(-1px); }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent), #1d4ed8);
      color: #fff;
      box-shadow: 0 3px 10px rgba(37,99,255,0.28);
    }
    .btn-primary:hover { box-shadow: 0 6px 18px rgba(37,99,255,0.38); }

    /* Disabled state while timer is running */
    .btn-primary.is-disabled {
      background: linear-gradient(135deg, #94a3b8, #64748b);
      box-shadow: none;
      pointer-events: none;
      cursor: not-allowed;
      opacity: 0.7;
    }

    .btn-ghost {
      background: transparent;
      color: var(--muted);
      border: 1.5px solid var(--line);
    }
    .btn-ghost:hover { background: var(--surface); color: var(--text); }

    /* ── Support note ── */
    .support-note {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 0.775rem;
      color: var(--muted);
      margin-top: 22px;
    }
    .support-note svg { flex-shrink: 0; opacity: 0.6; }

    /* ── Responsive ── */
    @media (max-width: 480px) {
      .error-card { padding: 36px 24px 32px; }
      .error-title span { font-size: 2.4rem; }
      .btn { width: 100%; justify-content: center; }
      .cooldown-wrap { max-width: 100%; }
    }
  </style>
</head>
<body>

  <div class="error-card">

    <!-- Brand -->
    <div class="card-brand">
      <div class="brand-logo">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <span class="brand-name">Team<em>Match</em></span>
    </div>

    <!-- Icon -->
    <div class="error-icon-wrap">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>

    <!-- Code badge -->
    <div class="error-code">
      <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
      Error 429 &nbsp;·&nbsp; Rate Limited
    </div>

    <!-- Title -->
    <h1 class="error-title">
      <span>429</span>
      Too Many Attempts
    </h1>

    <!-- Dynamic message from handler -->
    <p class="error-message"><%= message %></p>

    <!-- Countdown -->
    <div class="cooldown-wrap">
      <div class="cooldown-icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      </div>
      <div class="cooldown-text">
        <div class="cooldown-label">Try again in</div>
        <div class="cooldown-timer" id="countdown">5:00</div>
      </div>
    </div>

    <!-- Progress bar -->
    <div class="progress-wrap">
      <div class="progress-labels">
        <span>Locked</span>
        <span id="progressLabel">Unlocks in 5:00</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill"></div>
      </div>
    </div>

    <div class="error-divider"></div>

    <!-- Actions -->
    <div class="error-actions">
      <a href="/login" class="btn btn-primary is-disabled" id="retryBtn">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Try Again
      </a>
      <a href="/" class="btn btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Go Home
      </a>
    </div>

    <!-- Support note -->
    <div class="support-note">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      Accounts are locked for 5 minutes after 3 failed attempts.
    </div>

  </div>

  <script>
    // ── Countdown: 5 minutes (300s) matching windowMs in the rate limiter ──
    const LOCK_SECONDS  = 300;
    const countdown     = document.getElementById('countdown');
    const progressFill  = document.getElementById('progressFill');
    const progressLabel = document.getElementById('progressLabel');
    const retryBtn      = document.getElementById('retryBtn');

    // Persist start time in sessionStorage so a page refresh doesn't reset it
    const storageKey = 'tm_429_start';
    let startTime = parseInt(sessionStorage.getItem(storageKey), 10);
    if (!startTime || isNaN(startTime)) {
      startTime = Date.now();
      sessionStorage.setItem(storageKey, startTime);
    }

    function formatTime(secs) {
      const m = Math.floor(secs / 60);
      const s = secs % 60;
      return m + ':' + String(s).padStart(2, '0');
    }

    function tick() {
      const elapsed  = Math.floor((Date.now() - startTime) / 1000);
      const remaining = Math.max(LOCK_SECONDS - elapsed, 0);
      const pct = (remaining / LOCK_SECONDS) * 100;

      countdown.textContent     = formatTime(remaining);
      progressLabel.textContent = remaining > 0 ? 'Unlocks in ' + formatTime(remaining) : 'Unlocked';
      progressFill.style.width  = pct + '%';

      if (remaining <= 0) {
        clearInterval(timer);
        sessionStorage.removeItem(storageKey);
        retryBtn.classList.remove('is-disabled');
        countdown.textContent     = '0:00';
        progressLabel.textContent = 'Unlocked — you can try again';
      }
    }

    tick(); // run immediately so there's no 1s blank on load
    const timer = setInterval(tick, 1000);
  </script>

</body>
</html>
